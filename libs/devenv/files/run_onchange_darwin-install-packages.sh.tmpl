#!/bin/bash

# Note: Using || true to prevent CI failures from transient Homebrew issues
# (e.g., cask checksum mismatches when upstream updates before Homebrew)
# The packages will still be installed even if some fail
brew bundle --file=/dev/stdin <<EOF || true
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF